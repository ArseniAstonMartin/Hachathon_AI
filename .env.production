APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Пока образ локальный. Когда зальете в Docker Hub, замените имя.
APP_IMAGE_NAME=fastapi-auth-service
APP_IMAGE_TAG=prod-local

# Замените на ваш реальный публичный IP сервера перед первым запуском.
APP_BASE_URL=http://203.0.113.10
REVERSE_PROXY_SITE_ADDRESS=http://203.0.113.10

# Сгенерируете сами
INTERNAL_API_BEARER_TOKEN=replace-with-long-random-internal-token
WEBHOOK_SECRET_TOKEN=replace-with-long-random-webhook-secret

# Вставите сами
TELEGRAM_BOT_TOKEN=replace-with-real-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_public_bot_username

# Без домена и HTTPS используем polling
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=
TELEGRAM_API_BASE_URL=https://api.telegram.org

OPENAI_API_KEY=
OPENAI_MODEL_SEMANTIC_DIFF=gpt-5-mini
OPENAI_MODEL_SUMMARY=gpt-5-mini
OPENAI_REQUEST_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=2

# Все локально внутри compose
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fastapi_auth_service
POSTGRES_USER=fastapi_auth_service
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=

# Локальный MinIO внутри compose
S3_ENDPOINT_URL=http://storage:9000
S3_REGION=us-east-1
S3_BUCKET=fastapi-auth-service
S3_ACCESS_KEY_ID=replace-with-minio-access-key
S3_SECRET_ACCESS_KEY=replace-with-minio-secret-key
S3_SECURE=false
S3_PREFIX_SOURCE_DOCUMENTS=source
S3_PREFIX_REPORTS=report

WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_SECONDS=1
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=1
JOB_TIMEOUT_SECONDS=900

MAX_UPLOAD_FILE_SIZE_BYTES=10485760

# Если хотите строго MVP-only, поставьте .docx
# Если хотите оставить текущее поведение проекта, оставьте .docx,.pdf
ALLOWED_EXTENSIONS=.docx
ALLOWED_MIME_TYPES_DOCX=application/vnd.openxmlformats-officedocument.wordprocessingml.document

PRAVO_BY_BASE_URL=https://pravo.by
PRAVO_BY_TIMEOUT_SECONDS=15
PRAVO_BY_CACHE_TTL_SECONDS=3600
LEGAL_SOURCE_REQUIRED=true

REPORT_LOCALE=ru
REPORT_OUTPUT_FORMAT=docx
REPORT_TITLE_PREFIX=Сравнительный отчет
